{
  "_version": "1.0",
  "_note": "Maps OpenClaw raw command prefixes/patterns to normalized technique names. Add new entries here \u2014 no code changes needed. Keys are matched longest-first. 'unknown' is the fallback.",
  "patterns": [
    {
      "id": "port_scan",
      "description": "Network port scanning",
      "matches": [
        "nmap",
        "masscan",
        "rustscan"
      ],
      "example": "nmap -sV 10.0.1.100"
    },
    {
      "id": "service_fingerprint",
      "description": "Service version and banner detection",
      "matches": [
        "nmap -sV",
        "nmap -A",
        "netcat",
        "nc "
      ],
      "example": "nmap -sV -p 22,80,443 10.0.1.100"
    },
    {
      "id": "banner_grab",
      "description": "Raw banner grabbing",
      "matches": [
        "banner",
        "curl -I",
        "wget --server-response",
        "telnet"
      ],
      "example": "curl -I http://10.0.1.100"
    },
    {
      "id": "http_exploit",
      "description": "HTTP/web application attack",
      "matches": [
        "nikto",
        "gobuster",
        "dirb",
        "wfuzz",
        "ffuf",
        "curl -X POST"
      ],
      "example": "nikto -h http://10.0.1.100"
    },
    {
      "id": "sqli",
      "description": "SQL injection attempt",
      "matches": [
        "sqlmap"
      ],
      "example": "sqlmap -u http://10.0.1.100/login --data='user=a&pass=b'"
    },
    {
      "id": "ssh_brute",
      "description": "SSH brute force or credential spray",
      "matches": [
        "hydra -l",
        "hydra -L",
        "medusa -M ssh",
        "patator ssh_login",
        "ncrack -p 22"
      ],
      "example": "hydra -L users.txt -P pass.txt ssh://10.0.1.100"
    },
    {
      "id": "default_creds",
      "description": "Default credential attempt",
      "matches": [
        "default_creds",
        "default-creds",
        "hydra -s 21",
        "hydra -s 23",
        "ssh admin@",
        "ssh root@"
      ],
      "example": "ssh admin@10.0.1.100"
    },
    {
      "id": "cve_exploit_public",
      "description": "Known CVE exploit against public-facing service",
      "matches": [
        "msfconsole -x",
        "msf -x",
        "python exploit",
        "searchsploit --run",
        "exploit/multi/http",
        "exploit/unix/webapp"
      ],
      "example": "msfconsole -x 'use exploit/unix/webapp/...; run'"
    },
    {
      "id": "lateral_movement",
      "description": "Lateral movement between hosts",
      "matches": [
        "psexec",
        "wmiexec",
        "smbexec",
        "atexec",
        "dcomexec",
        "impacket"
      ],
      "example": "impacket-psexec domain/user:pass@10.0.2.50"
    },
    {
      "id": "smb_enum",
      "description": "SMB share and user enumeration",
      "matches": [
        "smbclient",
        "smbmap",
        "enum4linux",
        "crackmapexec smb",
        "nmap --script smb"
      ],
      "example": "smbmap -H 10.0.2.50"
    },
    {
      "id": "credential_reuse",
      "description": "Reusing harvested credentials",
      "matches": [
        "crackmapexec",
        "evil-winrm",
        "wsman",
        "pass-the-hash",
        "pth-"
      ],
      "example": "crackmapexec smb 10.0.2.0/24 -u admin -p 'harvested_pass'"
    },
    {
      "id": "internal_scan",
      "description": "Internal subnet reconnaissance",
      "matches": [
        "nmap 10.0.2",
        "nmap 192.168",
        "nmap 172.16",
        "arp-scan",
        "netdiscover"
      ],
      "example": "nmap -sn 10.0.2.0/24"
    },
    {
      "id": "firewall_bypass",
      "description": "Firewall evasion or bypass attempt",
      "matches": [
        "nmap -f",
        "nmap --mtu",
        "nmap -D",
        "fragroute",
        "ptunnel",
        "iodine"
      ],
      "example": "nmap -f --mtu 8 10.0.2.50"
    },
    {
      "id": "hash_dump",
      "description": "Credential/hash extraction from memory or disk",
      "matches": [
        "mimikatz",
        "secretsdump",
        "hashdump",
        "lsadump",
        "procdump",
        "ntdsutil"
      ],
      "example": "impacket-secretsdump domain/admin:pass@10.0.2.10"
    },
    {
      "id": "password_spray",
      "description": "Password spraying across multiple accounts",
      "matches": [
        "spray",
        "kerbrute",
        "ruler",
        "o365spray",
        "crackmapexec winrm",
        "crackmapexec ldap"
      ],
      "example": "kerbrute passwordspray -d domain.local users.txt Password1"
    },
    {
      "id": "ad_escalation",
      "description": "Active Directory privilege escalation",
      "matches": [
        "bloodhound",
        "sharphound",
        "powerview",
        "kerberoast",
        "asreproast",
        "dcsync",
        "golden ticket",
        "silver ticket",
        "printspoofer",
        "zerologon"
      ],
      "example": "impacket-secretsdump -just-dc domain/admin:pass@dc.domain.local"
    },
    {
      "id": "data_exfil",
      "description": "Data exfiltration simulation",
      "matches": [
        "exfil",
        "scp flag",
        "wget flag",
        "curl.*flag",
        "nc.*flag",
        "cat /flag",
        "type flag.txt"
      ],
      "example": "cat /flag.txt"
    },
    {
      "id": "persistence",
      "description": "Persistence mechanism installation",
      "matches": [
        "crontab",
        "at -f",
        "schtasks",
        "reg add.*run",
        "adduser",
        "useradd",
        "net user /add"
      ],
      "example": "crontab -e"
    }
  ],
  "fallback": "unknown"
}