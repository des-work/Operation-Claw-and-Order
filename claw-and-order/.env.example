# ── Claw & Order — Environment Configuration ────────────────────────────
# Copy this file to .env and fill in your values.
# All variables have sensible defaults except ADMIN_SECRET (required).

# ── Database ─────────────────────────────────────────────────────────────
# SQLite (development):
DATABASE_URL=sqlite+aiosqlite:///./claw_and_order.db
# PostgreSQL (production):
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/claw_and_order

# ── Authentication (REQUIRED) ───────────────────────────────────────────
# Shared secret for admin endpoints (POST /api/admin/phase)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
ADMIN_SECRET=

# ── Discord Integration (optional) ──────────────────────────────────────
# Bot token from https://discord.com/developers/applications
DISCORD_TOKEN=
# Channel ID for competition alerts (right-click channel → Copy ID)
DISCORD_CHANNEL_ID=0

# ── Logging ──────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── Tuning (optional) ───────────────────────────────────────────────────
# Max queued SSE messages per connected dashboard client
SSE_MAX_QUEUE_SIZE=256
# Max characters stored in event raw_output field
RAW_OUTPUT_MAX_LENGTH=2000
